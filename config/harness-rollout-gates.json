      "name": "Shadow",
      "start": "2026-03-09T00:00:00Z",
      "end": "2026-03-15T23:59:59Z",
      "mode": "report-only",
      "domains": ["all"],
      "exitGates": [
        {
          "id": "domain-coverage-100",
          "label": "Domain coverage is 100%",
          "windowDays": 30,
          "metric": "domainCoverage.coverageRate",
          "operator": ">=",
          "target": 1
        },
        {
          "id": "ingest-success-99",
          "label": "Ingest success is at least 99%",
          "windowDays": 30,
          "metric": "meta.ingestSuccessRate",
          "operator": ">=",
          "target": 0.99
        }
      ]
    },
    {
      "id": "week-2",
      "name": "Enforcement A",
      "start": "2026-03-16T00:00:00Z",
      "end": "2026-03-22T23:59:59Z",
      "mode": "enforce",
      "domains": ["memory", "model-hub", "omnichannel-gateway", "auth", "session", "security"],
      "exitGates": [
        {
          "id": "scenario-evidence-100",
          "label": "Agentic commits include scenario evidence",
          "windowDays": 7,
          "metric": "meta.scenarioEvidenceRate",
          "operator": ">=",
          "target": 1
        },
        {
          "id": "critical-reverts-zero",
          "label": "No critical auto-reverts",
          "windowDays": 7,
          "metric": "criticalFailAutoReverts",
          "operator": "<=",
          "target": 0
        }
      ]
    },
    {
      "id": "week-3",
      "name": "Enforcement B",
      "start": "2026-03-23T00:00:00Z",
      "end": "2026-03-29T23:59:59Z",
      "mode": "enforce",
      "domains": ["tasks", "project-workspace", "persona-rooms", "skills", "clawhub"],
      "exitGates": [
        {
          "id": "scenario-evidence-100",
          "label": "Agentic commits include scenario evidence",
          "windowDays": 7,
          "metric": "meta.scenarioEvidenceRate",
          "operator": ">=",
          "target": 1
        },
        {
          "id": "flaky-rate-below-2",
          "label": "Flaky rate stays below 2%",
          "windowDays": 7,
          "metric": "flakyRate",
          "operator": "<=",
          "target": 0.02
        }
      ]
    },
    {
      "id": "week-4",
      "name": "Enforcement C + Go/No-Go",
      "start": "2026-03-30T00:00:00Z",
      "end": "2026-04-05T23:59:59Z",
      "mode": "enforce",
      "domains": ["knowledge-base", "automation", "ops-observability", "master-agent", "core-api"],
      "exitGates": [
        {
          "id": "first-pass-plus-15pct",
          "label": "First-pass CI improves by 15% vs baseline",
          "windowDays": 30,
          "metric": "firstPassCiRate",
          "operator": ">=",
          "targetFromBaselineDelta": 0.15
