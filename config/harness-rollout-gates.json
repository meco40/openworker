        {
          "id": "revert-rate-not-higher",
          "label": "Revert rate is not higher than baseline",
          "windowDays": 30,
          "metric": "revertRate",
          "operator": "<=",
          "targetFromBaselineDelta": 0
        },
        {
          "id": "flaky-rate-below-2",
          "label": "Flaky rate stays below 2%",
          "windowDays": 7,
          "metric": "flakyRate",
          "operator": "<=",
          "target": 0.02
        }
      ]
    }
