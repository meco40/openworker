import { decryptSecret } from './crypto';
import { PROVIDER_CATALOG } from './providerCatalog';
import type { ProviderAccountRecord } from './repository';

const REQUEST_TIMEOUT_MS = 15_000;

export interface FetchedModel {
  id: string;
  name: string;
  provider: string;
  owned_by?: string;
  context_window?: number;
  created?: number;
}

async function fetchWithTimeout(input: RequestInfo | URL, init: RequestInit): Promise<Response> {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), REQUEST_TIMEOUT_MS);
  try {
    return await fetch(input, { ...init, signal: controller.signal });
  } finally {
    clearTimeout(timeout);
  }
}

function findProvider(providerId: string) {
  return PROVIDER_CATALOG.find((p) => p.id === providerId) ?? null;
}

// ---------- OpenAI-compatible list models ----------
async function fetchOpenAICompatibleModels(
  baseUrl: string,
  secret: string,
  providerId: string,
): Promise<FetchedModel[]> {
  const url = `${baseUrl.replace(/\/$/, '')}/models`;
  const response = await fetchWithTimeout(url, {
    method: 'GET',
    headers: { Authorization: `Bearer ${secret}` },
  });
  if (!response.ok) return [];
  const json = (await response.json()) as { data?: Array<{ id: string; owned_by?: string; created?: number }> };
  return (json.data ?? []).map((m) => ({
    id: m.id,
    name: m.id,
    provider: providerId,
    owned_by: m.owned_by,
    created: m.created,
  }));
}

// ---------- Gemini ----------
async function fetchGeminiModels(secret: string): Promise<FetchedModel[]> {
  const url = `https://generativelanguage.googleapis.com/v1beta/models?key=${encodeURIComponent(secret)}&pageSize=100`;
  const response = await fetchWithTimeout(url, { method: 'GET' });
  if (!response.ok) return [];
  const json = (await response.json()) as {
    models?: Array<{
      name: string;
      displayName: string;
      inputTokenLimit?: number;
    }>;
  };
  return (json.models ?? [])
    .filter((m) => m.name.startsWith('models/gemini'))
    .map((m) => ({
      id: m.name.replace('models/', ''),
      name: m.displayName || m.name.replace('models/', ''),
      provider: 'gemini',
      context_window: m.inputTokenLimit,
    }));
}

// ---------- Anthropic (static + known models) ----------
function fetchAnthropicModels(): FetchedModel[] {
  const models = [
    'claude-sonnet-4-5',
    'claude-3-7-sonnet-latest',
    'claude-3-5-haiku-latest',
    'claude-3-opus-latest',
    'claude-3-5-sonnet-latest',
  ];
  return models.map((id) => ({ id, name: id, provider: 'anthropic' }));
}

// ---------- Cohere ----------
async function fetchCohereModels(secret: string): Promise<FetchedModel[]> {
  const response = await fetchWithTimeout('https://api.cohere.com/v2/models', {
    method: 'GET',
    headers: { Authorization: `Bearer ${secret}` },
  });
  if (!response.ok) return [];
  const json = (await response.json()) as {
    models?: Array<{ name: string; endpoints?: string[] }>;
  };
  return (json.models ?? [])
    .filter((m) => m.endpoints?.includes('chat'))
    .map((m) => ({ id: m.name, name: m.name, provider: 'cohere' }));
}

// ---------- OpenRouter ----------
async function fetchOpenRouterModels(secret: string): Promise<FetchedModel[]> {
  const response = await fetchWithTimeout('https://openrouter.ai/api/v1/models', {
    method: 'GET',
    headers: { Authorization: `Bearer ${secret}` },
  });
  if (!response.ok) return [];
  const json = (await response.json()) as {
    data?: Array<{ id: string; name?: string; context_length?: number }>;
  };
  return (json.data ?? []).map((m) => ({
    id: m.id,
    name: m.name || m.id,
    provider: 'openrouter',
    context_window: m.context_length,
  }));
}

// ---------- GitHub Models ----------
async function fetchGitHubModels(secret: string): Promise<FetchedModel[]> {
  const response = await fetchWithTimeout('https://api.github.com/marketplace_listing/models', {
    method: 'GET',
    headers: {
      Authorization: `Bearer ${secret}`,
      Accept: 'application/vnd.github+json',
      'X-GitHub-Api-Version': '2022-11-28',
    },
  });
  if (!response.ok) {
    // Fallback: try models inference catalog
    const fallback = await fetchWithTimeout('https://models.inference.ai.azure.com/info', {
      method: 'GET',
      headers: { Authorization: `Bearer ${secret}` },
    }).catch(() => null);
    if (fallback?.ok) {
      const info = (await fallback.json().catch(() => ({}))) as Record<string, unknown>;
      if (Array.isArray(info)) {
        return (info as Array<{ id?: string; model_name?: string }>).map((m) => ({
          id: String(m.id || m.model_name || ''),
          name: String(m.model_name || m.id || ''),
          provider: 'github-copilot',
        }));
      }
    }
    // Return known GitHub Models
    return [
      { id: 'gpt-4o', name: 'GPT-4o (GitHub)', provider: 'github-copilot' },
      { id: 'gpt-4o-mini', name: 'GPT-4o Mini (GitHub)', provider: 'github-copilot' },
      { id: 'o1-preview', name: 'o1-preview (GitHub)', provider: 'github-copilot' },
      { id: 'o1-mini', name: 'o1-mini (GitHub)', provider: 'github-copilot' },
    ];
  }
  const json = (await response.json()) as Array<{ id?: string; name?: string; friendly_name?: string }>;
  return (Array.isArray(json) ? json : []).map((m) => ({
    id: String(m.id || m.name || ''),
    name: String(m.friendly_name || m.name || m.id || ''),
    provider: 'github-copilot',
  }));
}

// ---------- ByteDance (static, endpoint-based) ----------
function fetchByteDanceModels(): FetchedModel[] {
  return [
    { id: 'doubao-1-5-lite-32k-250115', name: 'Doubao 1.5 Lite 32K', provider: 'bytedance' },
    { id: 'doubao-1-5-pro-32k-250115', name: 'Doubao 1.5 Pro 32K', provider: 'bytedance' },
    { id: 'doubao-1-5-pro-256k-250115', name: 'Doubao 1.5 Pro 256K', provider: 'bytedance' },
  ];
}

/**
 * Fetches the list of available models for a provider account.
 * Uses provider-specific APIs where available, falls back to static defaults.
 */
export async function fetchModelsForAccount(
  account: ProviderAccountRecord,
  encryptionKey: string,
): Promise<FetchedModel[]> {
  const provider = findProvider(account.providerId);
  if (!provider) return [];

  const secret = decryptSecret(account.encryptedSecret, encryptionKey);
  if (!secret?.trim()) return [];

  try {
    switch (provider.id) {
      case 'gemini':
        return await fetchGeminiModels(secret);

      case 'openai':
        return await fetchOpenAICompatibleModels('https://api.openai.com/v1', secret, 'openai');

      case 'anthropic':
        return fetchAnthropicModels();

      case 'openrouter':
        return await fetchOpenRouterModels(secret);

      case 'xai':
        return await fetchOpenAICompatibleModels('https://api.x.ai/v1', secret, 'xai');

      case 'mistral':
        return await fetchOpenAICompatibleModels('https://api.mistral.ai/v1', secret, 'mistral');

      case 'cohere':
        return await fetchCohereModels(secret);

      case 'kimi':
        return await fetchOpenAICompatibleModels('https://api.moonshot.cn/v1', secret, 'kimi');

      case 'zai':
        return await fetchOpenAICompatibleModels(
          'https://api.z.ai/api/paas/v4',
          secret,
          'zai',
        );

      case 'bytedance':
        return fetchByteDanceModels();

      case 'github-copilot':
        return await fetchGitHubModels(secret);

      default: {
        // Generic OpenAI-compatible fallback
        if (provider.apiBaseUrl) {
          return await fetchOpenAICompatibleModels(provider.apiBaseUrl, secret, provider.id);
        }
        return provider.defaultModels.map((id) => ({
          id,
          name: id,
          provider: provider.id,
        }));
      }
    }
  } catch {
    // On failure, return static defaults so the UI always has something
    return provider.defaultModels.map((id) => ({
      id,
      name: id,
      provider: provider.id,
    }));
  }
}
