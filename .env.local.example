# Local development defaults (Mem0 runs on localhost:8010 via docker-compose.mem0-local.yml)
MEMORY_PROVIDER=mem0
MEM0_BASE_URL=http://127.0.0.1:8010
MEM0_API_KEY=local-mem0-dev-token
MEM0_API_PATH=/v1
MEM0_TIMEOUT_MS=5000
MEM0_READ_TIMEOUT_MS=5000
MEM0_WRITE_TIMEOUT_MS=15000
MEM0_MAX_RETRIES=3
MEM0_WRITE_MAX_RETRIES=1
MEM0_RETRY_BASE_DELAY_MS=500
MEM0_EMBEDDER_SYNC_TIMEOUT_MS=10000

# Embeddings used by Mem0 are auto-synced from Model Hub profile `p1-embeddings`
# via POST /configure/embedder on the mem0-local service.
# LLM used by Mem0 is auto-synced from Model Hub profile `p1`
# via POST /configure/llm on the mem0-local service.
#
# Optional bootstrap values (only needed if you want mem0-local preconfigured
# before the first Model Hub sync):
# MEM0_LLM_PROVIDER=
# MEM0_LLM_MODEL=
# MEM0_LLM_API_KEY=
# MEM0_LLM_BASE_URL=
# MEM0_EMBEDDER_PROVIDER=
# MEM0_EMBEDDER_MODEL=
# MEM0_EMBEDDER_API_KEY=
# MEM0_EMBEDDER_BASE_URL=
# MEM0_EMBEDDING_DIMS=768

# Optional but recommended for Model Hub crypto
MODEL_HUB_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Agent Room rollout flags
NEXT_PUBLIC_AGENT_ROOM_ENABLED=true
AGENT_ROOM_ENABLED=true
AGENT_V2_MAX_REQUESTS_PER_MINUTE=600
