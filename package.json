{
  "name": "openclaw-gateway-control-plane",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "dev:scheduler": "tsx watch scheduler.ts",
    "dev:next": "next dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "next build",
    "start:web": "node --import tsx server.ts",
    "start:scheduler": "node --import tsx scheduler.ts",
    "start": "npm run start:web",
    "memory:reset": "node --import tsx scripts/memory-reset.ts",
    "memory:cleanup-noise": "node --import tsx scripts/memory-cleanup-noise.ts",
    "memory:backfill-channel-scope": "node --import tsx scripts/memory-backfill-channel-scope.ts",
    "worker:openai:dev": "cd services/openai_worker && .venv\\Scripts\\python.exe -m uvicorn app.main:app --host 127.0.0.1 --port 8011 --reload",
    "worker:openai:test": "cd services/openai_worker && .venv\\Scripts\\python.exe -m pytest tests -q",
    "worker:openai:load": "npm run test -- tests/load/worker-openai-load.test.ts",
    "worker:openai:ci": "npm run typecheck && npm run test -- tests/unit/worker/openai-worker-runtime.test.ts tests/integration/worker/openai-event-ordering.test.ts tests/integration/worker/openai-duplicate-events.test.ts tests/integration/worker/openai-schema-version.test.ts tests/integration/worker/openai-runtime-failover.test.ts tests/integration/worker/openai-budget-enforcement.test.ts tests/integration/worker/openai-rate-limit.test.ts tests/load/worker-openai-load.test.ts && cd services/openai_worker && .venv\\Scripts\\python.exe -m pytest tests -q",
    "dev:stack": "npm run dev",
    "speckit:help": "pwsh -File .specify/scripts/powershell/check-prerequisites.ps1 -Help",
    "speckit:new": "pwsh -File .specify/scripts/powershell/create-new-feature.ps1",
    "speckit:plan:init": "pwsh -File .specify/scripts/powershell/setup-plan.ps1 -Json",
    "speckit:agent:update": "pwsh -File .specify/scripts/powershell/update-agent-context.ps1 -AgentType codex"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@google/genai": "^1.40.0",
    "@xyflow/react": "^12.10.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.10",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
