{
  "name": "openclaw-gateway-control-plane",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "dev:scheduler": "tsx watch scheduler.ts",
    "dev:next": "next dev",
    "cli": "node --import tsx src/cli/program.ts",
    "cli:gateway": "node --import tsx src/cli/program.ts gateway",
    "cli:channels": "node --import tsx src/cli/program.ts channels",
    "cli:node": "node --import tsx src/cli/program.ts node",
    "lint": "oxlint . --threads=1",
    "lint:fix": "oxlint . --fix --threads=1",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:smoke",
    "test:e2e:smoke": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:live": "node --import tsx scripts/e2e/live-preflight.ts && vitest run --config vitest.e2e.live.config.ts",
    "test:e2e:browser": "playwright test",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "knip": "knip",
    "start:web": "node --import tsx server.ts",
    "start:scheduler": "node --import tsx scheduler.ts",
    "start": "npm run start:web",
    "memory:reset": "node --import tsx scripts/memory-reset.ts",
    "memory:cleanup-noise": "node --import tsx scripts/memory-cleanup-noise.ts",
    "memory:backfill-channel-scope": "node --import tsx scripts/memory-backfill-channel-scope.ts",
    "local:cleanup": "node --import tsx scripts/cleanup-local-artifacts.ts --apply",
    "local:cleanup:dry": "node --import tsx scripts/cleanup-local-artifacts.ts --dry-run",
    "test:artifacts:clean": "node --import tsx scripts/cleanup-test-artifacts.ts --apply",
    "test:artifacts:clean:dry": "node --import tsx scripts/cleanup-test-artifacts.ts --dry-run",
    "workspaces:cleanup": "node --import tsx scripts/cleanup-task-workspaces.ts",
    "workspaces:cleanup:json": "node --import tsx scripts/cleanup-task-workspaces.ts --json",
    "knowledge:ingest": "node --import tsx scripts/trigger-knowledge-ingestion.ts",
    "attachments:consistency": "node --import tsx scripts/attachments-consistency.ts",
    "smoke:chat-cli-approval": "node --import tsx scripts/smoke-chat-cli-approval.ts",
    "avatar:sync-headaudio": "node scripts/avatar/sync-headaudio-assets.mjs",
    "avatar:validate": "node scripts/avatar/validate-master-avatar.mjs",
    "mem0:local:up": "docker compose --env-file .env.local -f docker-compose.mem0-local.yml up -d --build",
    "mem0:local:down": "docker compose --env-file .env.local -f docker-compose.mem0-local.yml down",
    "mem0:local:logs": "docker compose --env-file .env.local -f docker-compose.mem0-local.yml logs -f mem0-local mem0-postgres",
    "mem0:local:ps": "docker compose --env-file .env.local -f docker-compose.mem0-local.yml ps",
    "dev:stack": "npm run dev",
    "speckit:help": "pwsh -File .specify/scripts/powershell/check-prerequisites.ps1 -Help",
    "speckit:new": "pwsh -File .specify/scripts/powershell/create-new-feature.ps1",
    "speckit:plan:init": "pwsh -File .specify/scripts/powershell/setup-plan.ps1 -Json",
    "speckit:agent:update": "pwsh -File .specify/scripts/powershell/update-agent-context.ps1 -AgentType codex",
    "postinstall": "npm run avatar:sync-headaudio",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/genai": "^1.42.0",
    "@met4citizen/headaudio": "0.1.0",
    "@met4citizen/talkinghead": "1.7.0",
    "@next/env": "^16.1.6",
    "@types/three": "^0.183.1",
    "@xyflow/react": "^12.10.0",
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "css-tree": "^3.1.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.12.3",
    "next": "^16.1.6",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.13",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "three": "^0.183.2",
    "ws": "^8.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^22.19.10",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "oxlint": "^1.48.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.1",
    "rimraf": "^6.1.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "oxlint --fix --threads=1",
      "prettier --write"
    ],
    "*.{json,md,css,scss,yml,yaml}": "prettier --write"
  },
  "knip": {
    "ignore": [
      "backups/**",
      "workspaces/**",
      ".worktrees/**",
      "demo/**",
      ".tmp/**",
      ".local/**",
      ".next/**",
      "dist/**",
      ".specify/**",
      ".codex/**"
    ]
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a"
}
