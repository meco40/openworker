const BrainstormSession: React.FC<{
room: RoomState,
personas: Persona[],
onToggle: () => void,
onDelete: () => void,
onUpdateRoom: (updates: Partial<RoomState>) => void
}> = ({ room, personas, onToggle, onDelete, onUpdateRoom }) => {
const [activeSpeakerId, setActiveSpeakerId] = useState<string | null>(null);
const [viewMode, setViewMode] = useState<'split' | 'chat' | 'board'>('split');
const [activeTab, setActiveTab] = useState<'draft' | 'diagram' | 'history' | 'friction'>('draft');
const [isAddMemberOpen, setIsAddMemberOpen] = useState(false);
const scrollRef = useRef<HTMLDivElement>(null);
const loopRef = useRef<any>(null);

useEffect(() => {
if (scrollRef.current) scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
}, [room.messages, activeSpeakerId]);

useEffect(() => {
if (room.status !== 'running') {
if (loopRef.current) clearInterval(loopRef.current);
return;
}

    loopRef.current = setInterval(async () => {
      if (activeSpeakerId || room.currentPhase === 'Complete') return;

      const orchestratorId = room.members.find(m => m.role === 'Orchestrator')?.personaId || personas[0].id;
      const specialists = room.members.filter(m => m.role !== 'Orchestrator').map(m => m.personaId);

      let nextPersonaId = (room.messages.length % 3 === 0) ? orchestratorId : specialists[Math.floor(Math.random() * specialists.length)];
      triggerTurn(nextPersonaId);
    }, 8000);

    return () => clearInterval(loopRef.current);

}, [room.status, activeSpeakerId, room.currentPhase, room.messages.length]);

const triggerTurn = async (personaId: string) => {
const persona = personas.find(p => p.id === personaId);
if (!persona) return;
setActiveSpeakerId(personaId);
try {
const history = room.messages.slice(-8).map(m => `${m.role === 'user' ? 'OPERATOR' : personas.find(px=>px.id===m.personaId)?.name}: ${m.content}`).join('\n');
const isOrchestrator = room.members.find(m => m.personaId === personaId)?.role === 'Orchestrator';

      const sys = `
        ${persona.systemInstruction}
        ---
        CURRENT ROOM: ${room.name}
        GOAL: ${room.description}
        PHASE: ${room.currentPhase}
        ---
        RULES:
        1. Keep messages concise.
        2. Use [VOTE:UP] or [VOTE:DOWN] to show consensus.
        3. If you propose a flow, use a Mermaid block: \`\`\`mermaid graph TD ... \`\`\`.
        4. ONLY Orchestrator can use [CHANGE_PHASE:Name].
        Phases: Analysis -> Ideation -> Critique -> Synthesis -> Complete.
      `;

      const response = await getGeminiResponse(
        `History:\n${history}\n\nYour contribution as ${persona.name}:`,
        sys,
        'gemini-3-flash-preview',
        { useSearch: room.useSearch, useMaps: room.useMaps }
      );

      let cleanResponse = response;
      let consensusDelta = 0;
      let vote: 'up' | 'down' | null = null;

      // Extract and clean Tags
      if (/\[VOTE:UP\]/i.test(cleanResponse)) {
        consensusDelta = 8;
        vote = 'up';
      }
      if (/\[VOTE:DOWN\]/i.test(cleanResponse)) {
        consensusDelta = -12;
        vote = 'down';

        // Friction tracking: If someone disagrees, track who they are disagreeing with (last speaker)
        const lastMsg = room.messages[room.messages.length - 1];
        if (lastMsg && lastMsg.personaId && lastMsg.personaId !== personaId) {
          const pair = [personaId, lastMsg.personaId].sort().join(':');
          const currentFriction = (room.friction || {})[pair] || 0;
          onUpdateRoom({ friction: { ...(room.friction || {}), [pair]: currentFriction + 1 } });
        }
      }

      cleanResponse = cleanResponse.replace(/\[VOTE:UP\]|\[VOTE:DOWN\]/gi, '').trim();

      if (isOrchestrator && /\[CHANGE_PHASE:(.*?)\]/i.test(cleanResponse)) {
        const match = cleanResponse.match(/\[CHANGE_PHASE:(.*?)\]/i);
        if (match) {
          onUpdateRoom({ currentPhase: match[1] as any });
          cleanResponse = cleanResponse.replace(match[0], '').trim();
        }
      }

      // Mermaid Logic
      const mermaidMatch = response.match(/```mermaid([\s\S]*?)```/i);
      if (mermaidMatch) {
        onUpdateRoom({ diagramData: mermaidMatch[1].trim() });
        setActiveTab('diagram');
      }

      // Draft Update: Ensure the board stays alive
      if (room.currentPhase === 'Synthesis' || room.currentPhase === 'Complete' || (isOrchestrator && cleanResponse.length > 200)) {
        const newHistory = room.solutionDraft ? [room.solutionDraft, ...(room.draftHistory || [])].slice(0, 10) : (room.draftHistory || []);
        onUpdateRoom({ solutionDraft: cleanResponse, draftHistory: newHistory });
      } else if (!room.solutionDraft && isOrchestrator) {
        onUpdateRoom({ solutionDraft: "Analysis Started: " + cleanResponse.substring(0, 300) + "..." });
      }

      onUpdateRoom({
        messages: [...room.messages, {
          id: Date.now().toString(),
          role: 'model',
          personaId,
          content: cleanResponse,
          timestamp: Date.now(),
          channel: 'Room',
          metadata: { vote }
        }],
        consensusScore: Math.max(0, Math.min(100, room.consensusScore + consensusDelta))
      });

    } catch (e) {
      console.error(e);
    } finally {
      setActiveSpeakerId(null);
    }

};

const forceNextPhase = () => {
const phases: any[] = ['Analysis', 'Ideation', 'Critique', 'Synthesis', 'Complete'];
const idx = phases.indexOf(room.currentPhase);
if (idx < phases.length - 1) onUpdateRoom({ currentPhase: phases[idx + 1] });
};

