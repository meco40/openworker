            className="p-2.5 text-slate-600 hover:text-rose-500 transition-colors cursor-pointer z-30"
            title="Delete Swarm"
          >
            <Trash2 size={18} />
          </button>
        </div>
      </header>

      <div className="flex-1 flex overflow-hidden relative">
        {/* Dialogue Stream */}
        <div className={`flex flex-col transition-all duration-500 border-r border-white/5 bg-[#020617] ${viewMode === 'chat' ? 'w-full' : viewMode === 'board' ? 'w-0 opacity-0' : 'w-[42%]'}`}>
          <div className="p-6 border-b border-white/5 bg-slate-900/20">
            <PhaseStepper currentPhase={room.currentPhase} />
          </div>
          <div ref={scrollRef} className="flex-1 overflow-y-auto p-8 space-y-10 custom-scrollbar">
            <div className="max-w-xl mx-auto space-y-8 pb-12">
              <div className="p-6 bg-blue-500/5 border border-blue-500/10 rounded-3xl text-[10px] text-slate-400 text-center uppercase tracking-widest leading-relaxed">
                Mission: "{room.description}"
              </div>
              {room.messages.map(m => (
                <ChatMessage key={m.id} msg={m} personas={personas} />
              ))}
              {activeSpeakerId && <TypingIndicator persona={personas.find(p => p.id === activeSpeakerId)!} />}
            </div>
          </div>
          <div className="p-6 border-t border-white/5 bg-black/20">
             <div className="max-w-xl mx-auto relative group">
                <input className="w-full bg-slate-900/50 border border-slate-800 rounded-2xl py-4 px-6 outline-none focus:border-blue-500 transition-all text-xs text-white" placeholder="Operator guidance input..." />
                <button className="absolute right-3 top-1/2 -translate-y-1/2 p-2 text-slate-600 group-hover:text-blue-500"><Send size={18} /></button>
             </div>
          </div>
        </div>

        {/* Synthesis Board */}
        <div className={`flex flex-col transition-all duration-500 bg-[#010409] ${viewMode === 'board' ? 'w-full' : viewMode === 'chat' ? 'w-0 opacity-0' : 'w-[58%]'}`}>
           <div className="h-14 border-b border-white/5 px-8 flex items-center gap-4 bg-slate-900/10 backdrop-blur-md overflow-x-auto custom-scrollbar">
              <button onClick={() => setActiveTab('draft')} className={`text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-lg transition-all whitespace-nowrap ${activeTab === 'draft' ? 'bg-blue-600 text-white shadow-lg' : 'text-slate-500 hover:text-slate-300'}`}>
                <FileText size={14} className="inline mr-2" /> Solution Artifact
              </button>
              <button onClick={() => setActiveTab('diagram')} className={`text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-lg transition-all whitespace-nowrap ${activeTab === 'diagram' ? 'bg-indigo-600 text-white shadow-lg' : 'text-slate-500 hover:text-slate-300'}`}>
                <Workflow size={14} className="inline mr-2" /> Logic Graph
              </button>
              <button onClick={() => setActiveTab('history')} className={`text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-lg transition-all whitespace-nowrap ${activeTab === 'history' ? 'bg-amber-600 text-white shadow-lg' : 'text-slate-500 hover:text-slate-300'}`}>
                <Clock size={14} className="inline mr-2" /> History
              </button>
              <button onClick={() => setActiveTab('friction')} className={`text-[10px] font-black uppercase tracking-[0.2em] px-4 py-2 rounded-lg transition-all whitespace-nowrap ${activeTab === 'friction' ? 'bg-rose-600 text-white shadow-lg' : 'text-slate-500 hover:text-slate-300'}`}>
                <Activity size={14} className="inline mr-2" /> Conflict Radar
              </button>
           </div>

           <div className="flex-1 overflow-y-auto p-12 custom-scrollbar">
              <div className="max-w-4xl mx-auto">
                  {activeTab === 'draft' ? (
                    <div className="animate-in fade-in duration-700 bg-slate-900/20 border border-slate-800/60 rounded-[3rem] p-12 shadow-2xl relative min-h-[600px]">
                       <div className="flex items-center gap-4 mb-10 text-slate-500">
                          <Terminal size={20} className="text-blue-500" />
                          <span className="text-[10px] font-black uppercase tracking-[0.5em]">Synthesis Buffer // Active Phase: {room.currentPhase}</span>
                       </div>
                       {room.solutionDraft ? (
                         <div className="prose prose-invert max-w-none text-slate-300 leading-[1.8] text-base whitespace-pre-wrap font-medium font-sans">
                           {room.solutionDraft}
                         </div>
                       ) : (
                         <div className="h-96 flex flex-col items-center justify-center text-center opacity-20 italic">
                            <Sparkles size={64} className="mb-6 text-blue-500" />
                            <p className="text-sm font-black uppercase tracking-[0.3em]">Agents are currently analyzing the problem.<br/>The artifact buffer is preparing for synthesis.</p>
                         </div>
                       )}
                    </div>
                  ) : activeTab === 'diagram' ? (
                    <div className="animate-in slide-in-from-bottom-4 duration-700 bg-slate-900/10 border border-slate-800/40 rounded-[3rem] p-12 min-h-[600px] flex flex-col shadow-inner">
                       <div className="flex items-center justify-between mb-10">
                          <div className="flex items-center gap-4 text-indigo-400">
                             <Workflow size={24} />
                             <span className="text-[10px] font-black uppercase tracking-[0.5em]">Diagram Engine Canvas</span>
                          </div>
                          <div className="px-4 py-1.5 bg-indigo-500/10 text-indigo-400 rounded-full text-[9px] font-black uppercase border border-indigo-400/20 tracking-widest">SVG Render Protocol</div>
                       </div>
                       {room.diagramData ? (
                         <div className="flex-1 space-y-8 flex flex-col items-center">
                            <MermaidRenderer chart={room.diagramData} />
                            <div className="w-full bg-black/40 p-6 rounded-2xl border border-slate-800 font-mono text-[10px] text-slate-500 leading-relaxed overflow-x-auto">
                              <div className="text-slate-600 mb-2 font-black uppercase tracking-widest">Source Logic:</div>
                              {room.diagramData}
                            </div>
                         </div>
                       ) : (
                         <div className="h-96 flex flex-col items-center justify-center text-center opacity-20">
                            <FileCode size={64} className="mb-6 text-indigo-500" />
                            <p className="uppercase font-black text-xs tracking-[0.4em]">Waiting for visual architecture proposals...</p>
                         </div>
                       )}
                    </div>
                  ) : activeTab === 'history' ? (
                    <div className="animate-in fade-in duration-500 space-y-6">
                      <h3 className="text-sm font-black text-white uppercase tracking-widest mb-8">Artifact Version History</h3>
                      {room.draftHistory?.length > 0 ? (
                        room.draftHistory.map((draft, i) => (
                          <div key={i} className="bg-slate-900/40 border border-slate-800 p-6 rounded-2xl hover:border-blue-500/30 transition-all group cursor-pointer" onClick={() => onUpdateRoom({ solutionDraft: draft })}>
                            <div className="flex justify-between items-center mb-4">
                              <span className="text-[10px] font-black text-slate-500 uppercase tracking-widest">Version v{room.draftHistory.length - i}</span>
                              <button className="text-[9px] font-black text-blue-500 uppercase opacity-0 group-hover:opacity-100 transition-opacity">Restore this version</button>
                            </div>
                            <p className="text-xs text-slate-400 line-clamp-3 italic">"{draft.substring(0, 200)}..."</p>
                          </div>
                        ))
                      ) : (
                        <div className="text-center py-20 text-slate-600 uppercase font-black text-[10px] tracking-widest">No previous versions recorded.</div>
                      )}
                    </div>
                  ) : (
                    <div className="animate-in fade-in duration-500 space-y-8">
                      <div className="flex items-center justify-between mb-4">
                        <h3 className="text-sm font-black text-white uppercase tracking-widest">Conflict Radar</h3>
                        <div className="flex items-center gap-2 text-rose-500 animate-pulse">
                          <AlertTriangle size={14} />
                          <span className="text-[9px] font-black uppercase tracking-widest">Live Friction Analysis</span>
                        </div>
                      </div>

                      {Object.keys(room.friction || {}).length > 0 ? (
                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                          {Object.entries(room.friction || {}).map(([pair, count]) => {
                            const [id1, id2] = pair.split(':');
                            const p1 = personas.find(p => p.id === id1);
                            const p2 = personas.find(p => p.id === id2);
                            return (
                              <div key={pair} className="bg-rose-500/5 border border-rose-500/20 p-6 rounded-2xl flex flex-col items-center text-center">
                                <div className="flex items-center gap-4 mb-4">
                                  <img src={p1?.avatar} className="w-10 h-10 rounded-xl border border-rose-500/30" />
                                  <div className="h-px w-8 bg-rose-500/30 relative">
                                    <div className="absolute inset-0 flex items-center justify-center">
                                      <X size={10} className="text-rose-500" />
                                    </div>
                                  </div>
                                  <img src={p2?.avatar} className="w-10 h-10 rounded-xl border border-rose-500/30" />
                                </div>
                                <div className="text-[10px] font-black text-slate-300 uppercase tracking-widest mb-1">{p1?.name} vs {p2?.name}</div>
                                <div className="text-[9px] font-bold text-rose-500 uppercase tracking-widest">{count} Disagreements</div>
                              </div>
                            );
                          })}
                        </div>
                      ) : (
                        <div className="text-center py-20">
                          <CheckCircle2 size={48} className="text-emerald-500/20 mx-auto mb-4" />
                          <p className="text-slate-600 uppercase font-black text-[10px] tracking-widest">Neural Harmony: No conflicts detected.</p>
                        </div>
                      )}
                    </div>
                  )}
              </div>
           </div>
        </div>
      </div>

      {isAddMemberOpen && (
        <div className="fixed inset-0 z-[100] flex items-center justify-center p-8 bg-black/90 backdrop-blur-2xl animate-in zoom-in-95 duration-400">
          <div className="w-full max-w-md bg-slate-900 border border-slate-800 rounded-[2.5rem] p-10 space-y-8 shadow-2xl">
            <div className="flex items-center gap-4">
              <div className="w-12 h-12 bg-blue-600 rounded-xl flex items-center justify-center text-white shadow-xl">
                <UserPlus size={24} />
              </div>
              <div>
                <h2 className="text-lg font-black text-white uppercase tracking-tight">Deploy Specialist</h2>
                <p className="text-[9px] text-blue-400 font-black uppercase tracking-[0.3em]">Dynamic Swarm Expansion</p>
              </div>
            </div>

            <div className="grid grid-cols-2 gap-4 max-h-96 overflow-y-auto pr-2 custom-scrollbar">
              {personas.filter(p => !room.members.find(m => m.personaId === p.id)).map(p => (
                <button
                  key={p.id}
                  onClick={() => {
                    onUpdateRoom({ members: [...room.members, { personaId: p.id, role: 'Specialist', status: 'Idle' }] });
                    setIsAddMemberOpen(false);
                  }}
                  className="flex flex-col items-center gap-3 p-4 bg-slate-950 border border-slate-800 rounded-2xl hover:border-blue-500/50 transition-all group"
                >
                  <img src={p.avatar} className="w-12 h-12 rounded-xl object-cover border border-slate-800 group-hover:border-blue-500/30" />
                  <span className="text-[10px] font-black text-slate-400 uppercase tracking-widest group-hover:text-white">{p.name}</span>
                </button>
              ))}
            </div>

            <button onClick={() => setIsAddMemberOpen(false)} className="w-full py-4 font-black text-slate-500 uppercase text-[10px] tracking-[0.3em] hover:text-white transition-colors">Cancel</button>
          </div>
        </div>
      )}
    </div>

);
};

const ChatMessage: React.FC<{ msg: Message, personas: Persona[] }> = ({ msg, personas }) => {
const p = personas.find(x => x.id === msg.personaId);
const isUser = msg.role === 'user';
const vote = msg.metadata?.vote;

return (

<div className={`flex gap-5 group ${isUser ? 'flex-row-reverse text-right' : ''} animate-in fade-in duration-500`}>
<div className={`w-10 h-10 rounded-xl shrink-0 overflow-hidden border-2 transition-transform hover:scale-105 ${isUser ? 'bg-blue-600 border-blue-500' : 'bg-slate-900 border-slate-800 shadow-lg shadow-black/40'}`}>
{isUser ? <div className="w-full h-full flex items-center justify-center font-black text-white text-xs">OP</div> : <img src={p?.avatar} className="w-full h-full object-cover" />}
</div>
<div className={`space-y-2.5 flex flex-col ${isUser ? 'items-end' : 'items-start'}`}>
<div className="flex items-center gap-3 text-[10px] font-black text-slate-600 uppercase tracking-widest">
<span className="text-slate-300">{isUser ? 'Operator' : p?.name}</span>
<span className="opacity-20">•</span>
<span className="opacity-20">{new Date(msg.timestamp).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</span>
{vote && (
<div className={`flex items-center gap-1 px-1.5 py-0.5 rounded border ${
               vote === 'up' ? 'bg-emerald-500/10 border-emerald-500/20 text-emerald-500' : 'bg-rose-500/10 border-rose-500/20 text-rose-500'
             }`}>
{vote === 'up' ? <Sparkles size={8} /> : <X size={8} />}
<span className="text-[7px] font-black">{vote === 'up' ? 'AGREE' : 'DISAGREE'}</span>
</div>
)}
</div>
<div className={`p-5 rounded-2xl text-[13px] leading-relaxed shadow-xl border transition-all ${
          isUser 
            ? 'bg-blue-600 border-blue-500 text-white rounded-tr-none' 
            : 'bg-slate-900 border-slate-800/60 text-slate-300 rounded-tl-none backdrop-blur-sm'
        }`}>
{msg.content}
</div>
</div>
</div>
);
};

const TypingIndicator: React.FC<{ persona: Persona }> = ({ persona }) => (

  <div className="flex gap-5 animate-pulse">
    <img src={persona.avatar} className="w-10 h-10 rounded-xl border border-slate-800 opacity-40 grayscale" />
    <div className="space-y-2">
      <div className="text-[10px] font-black text-slate-600 uppercase tracking-widest">{persona.name} processing...</div>
      <div className="w-24 h-4 bg-slate-900/50 border border-slate-800 rounded-lg"></div>
    </div>
  </div>
);

const ViewToggle = ({ icon: Icon, active, onClick }: any) => (
<button onClick={onClick} className={`p-2.5 rounded-xl transition-all ${active ? 'bg-blue-600 text-white shadow-2xl shadow-blue-900/40' : 'text-slate-600 hover:text-slate-400 hover:bg-white/5'}`}>
<Icon size={18} />
</button>
);

const CreateRoomModal: React.FC<{ personas: Persona[], onClose: () => void, onConfirm: (r: any) => void }> = ({ personas, onClose, onConfirm }) => {
const [name, setName] = useState('');
const [description, setDescription] = useState('');

const handleInit = () => {
if (!name || !description) return;
onConfirm({
id: `SW-${Math.floor(Math.random() * 8999) + 1000}`,
name,
description,
createdAt: Date.now(),
members: personas.map((p, i) => ({ personaId: p.id, role: i === 0 ? 'Orchestrator' : 'Specialist', status: 'Idle' })),
messages: []
});
};

return (

<div className="fixed inset-0 z-[100] flex items-center justify-center p-8 bg-black/90 backdrop-blur-2xl animate-in zoom-in-95 duration-400">
<div className="w-full max-w-xl bg-slate-900 border border-slate-800 rounded-[3rem] p-12 space-y-10 shadow-2xl relative">
<div className="flex items-center gap-6">
<div className="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-2xl shadow-blue-500/20">
<Target size={36} />
</div>
<div>
<h2 className="text-2xl font-black text-white uppercase tracking-tighter">New Mission</h2>
<p className="text-[10px] text-blue-500 font-black uppercase tracking-[0.4em] mt-1.5">Define Swarm Protocols</p>
</div>
</div>
<div className="space-y-6">
<input autoFocus value={name} onChange={e => setName(e.target.value)} placeholder="Swarm Designation Name..." className="w-full bg-slate-950 border border-slate-800 rounded-2xl p-6 text-white outline-none focus:border-blue-500 font-black text-lg transition-all" />
<textarea value={description} onChange={e => setDescription(e.target.value)} placeholder="Specific Mission Objective..." className="w-full bg-slate-950 border border-slate-800 rounded-2xl p-8 text-white outline-none focus:border-blue-500 min-h-[160px] resize-none leading-relaxed text-sm font-medium transition-all" />
</div>
<div className="flex gap-6 pt-6">
<button onClick={onClose} className="flex-1 py-5 font-black text-slate-500 uppercase text-[10px] tracking-[0.3em] hover:text-white transition-colors">Abort</button>
<button onClick={handleInit} className="flex-[2] bg-blue-600 text-white font-black py-5 rounded-2xl shadow-2xl uppercase text-[10px] tracking-[0.3em] active:scale-95 transition-all">Initiate Collective</button>
</div>
</div>
</div>
);
};

export default RoomsView;
